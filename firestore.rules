rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default deny ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ───────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function isUser(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function role() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isTeacherOrAdmin() { return isSignedIn() && role() in ['teacher', 'admin']; }
    function isAdmin() { return isSignedIn() && role() == 'admin'; }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isUser(userId);
      allow update: if isUser(userId) || isAdmin();
      allow delete: if isAdmin();

      // Sparks wallet ledger
      match /spark_transactions/{txId} {
        allow read, create: if isUser(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // ── Programmes (curriculum) ───────────────────────────────
    match /programmes/{programmeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── Unit mastery quiz attempts ────────────────────────────
    match /unit_quiz_attempts/{attemptId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid
        || isTeacherOrAdmin()
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.childIds.hasAny([resource.data.studentId])
      );
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Courses ───────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create: if isTeacherOrAdmin();
      allow update: if isTeacherOrAdmin();
      allow delete: if isAdmin();

      match /enrollments/{studentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isAdmin();
      }

      match /modules/{moduleId} {
        allow read: if isSignedIn();
        allow create, update: if isTeacherOrAdmin();
        allow delete: if isAdmin();

        match /lessons/{lessonId} {
          allow read: if isSignedIn();
          allow create, update: if isTeacherOrAdmin();
          allow delete: if isAdmin();
        }
      }
    }

    // ── Institutions ──────────────────────────────────────────
    match /institutions/{institutionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── Badges ────────────────────────────────────────────────
    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Messages ──────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.fromId == request.auth.uid ||
        resource.data.toId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.toId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Lesson Notes ─────────────────────────────────────────
    match /lesson_notes/{noteId} {
      allow read, write: if isSignedIn();
    }

    // ── Submissions ───────────────────────────────────────────
    match /submissions/{submissionId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || isTeacherOrAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isTeacherOrAdmin();
      allow delete: if isAdmin();
    }

    // ── Live Classes ──────────────────────────────────────────
    match /live_classes/{classId} {
      allow read: if isSignedIn();
      allow create, update: if isTeacherOrAdmin();
      allow delete: if isAdmin();
    }
  }
}
